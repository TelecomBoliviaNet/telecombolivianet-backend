# ══════════════════════════════════════════════════════════════
# TELECOM BOLIVIANET — Variables de entorno globales
# Copiar a .env y completar TODAS las variables antes de
# ejecutar docker compose up en producción.
# ══════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────
DB_PASSWORD=cambiar_password_bd_aqui
CHATBOT_DB_PASSWORD=cambiar_password_chatbot_aqui

# ── JWT — OBLIGATORIO, sin valor por defecto en producción ────
# Generar con: openssl rand -base64 48
# Mínimo 32 caracteres. Nunca usar el valor de ejemplo abajo.
JWT_KEY=REEMPLAZAR_con_clave_aleatoria_minimo_32_chars

# ── Cifrado de secrets en BD (BUG F FIX) ─────────────────────
# Clave AES-256 para cifrar WhatsApp Token en la tabla SystemConfig.
# Generar con: openssl rand -base64 32
# CRÍTICO: diferente a JWT_KEY. Nunca compartir ni versionar.
# Si se pierde esta clave, los tokens cifrados en BD NO son recuperables.
SECRET_ENCRYPTION_KEY=REEMPLAZAR_con_clave_cifrado_32_chars_distinta_a_JWT

# ── WhatsApp Meta Business ────────────────────────────────────
# Obtener en: developers.facebook.com → Tu App → WhatsApp → API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost
FRONTEND_PORT=80
